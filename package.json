    "db:push:pg": "drizzle-kit push --config=drizzle-pg.config.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "npx playwright test",
    "test:components": "vitest run tests/components/"
