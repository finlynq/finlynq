  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "build:mcp": "npx tsx mcp-server/index.ts",
    "db:generate": "drizzle-kit generate",
    "db:generate:pg": "drizzle-kit generate --config=drizzle-pg.config.ts",
    "db:push": "drizzle-kit push",
