/.next-test/
/.next-verify/
/build.log
/pf-managed*.log
/pf-managed.log
/test-results/
/e2e/
*.ps1

# Hosted-mode build overlay (managed finlynq.com only). These paths are
# rsynced in from a private repo on the hosted box before `npm run build` and
# must never be tracked here — the public app is complete without them.
# See docs/cloud-overlay.md.
/src/app/(cloud)/
/src/lib/cloud/

# Internal working docs, plans + design references — NOT exposed in the public
# repo. Holds per-feature implementation plans (authored by /triage), the
# architecture/ design docs (backfill, bank-ledger, webhook-events,
# stdio-mcp-write-decision, …), ops playbooks (migrations, resend-inbound-setup,
# privacy-hardening-deploy), and contributor references (invariants, ui-design,
# reconciliation, transaction-rules-v2, import-connectors, dev-worktrees, seo).
# Only the end-user docs live in /docs/ (getting-started, faq, mobile-setup) and
# ARE tracked + public. CLAUDE.md links to plan/ docs resolve in the working tree.
/plan/

# Auto-regenerated by scripts/generate-mcp-tool-catalog.mjs on every
# `npm run build`. Source-of-truth is mcp-server/register-tools-pg.ts (tracked).
# Tracking this file was causing recurring SSH-deploy failures on the dev VPS:
# every deploy regenerated it locally, but the GH Actions workflow's
# `git checkout -B dev origin/dev` step would abort on the local-mod conflict.
# De-tracked + gitignored so the conflict can't happen; the file is rebuilt
# fresh from source on every build (CI + deploy).
/src/app/mcp-guide/tools/tools.generated.ts
