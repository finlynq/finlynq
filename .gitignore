# Triage plan working docs (per-feature implementation plans authored by
# /triage, consumed by /drain-pending-tasks; living feature doc lands in
# docs/<slug>.md at ship time and IS tracked).
/plan/

# Internal architecture / design docs (2026-06-09). User-facing docs at
# /docs/{getting-started,faq,mobile-setup,ui-design,reconciliation,...}.md
# stay tracked; the architecture/ subfolder is the internal design
# reference (backfill.md, bank-ledger.md, encryption.md, mcp.md,
# database.md, stdio-mcp-write-decision.md, webhook-events.md) and is
# gitignored so it doesn't leak through the public open-source repo.
# CLAUDE.md still links to these — links work in the working tree, will
# 404 on GitHub. Already-tracked files in this folder were detached via
# `git rm --cached` at the same commit that introduced this rule.
/docs/architecture/

# Auto-regenerated by scripts/generate-mcp-tool-catalog.mjs on every
# `npm run build`. Source-of-truth is mcp-server/register-tools-pg.ts (tracked).
# Tracking this file was causing recurring SSH-deploy failures on the dev VPS:
# every deploy regenerated it locally, but the GH Actions workflow's
# `git checkout -B dev origin/dev` step would abort on the local-mod conflict.
# De-tracked + gitignored so the conflict can't happen; the file is rebuilt
# fresh from source on every build (CI + deploy).
/src/app/mcp-guide/tools/tools.generated.ts
