# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=production

# Public URL of the app (used in email links, CORS, etc.)
APP_URL=https://your-domain.com

# Comma-separated list of allowed origins for CORS (managed mode only)
# Leave blank for single-domain deployments behind Nginx
ALLOWED_ORIGINS=

# ─── Database ─────────────────────────────────────────────────────────────────
# Full PostgreSQL connection string.
# Setting this env var activates managed (PostgreSQL) mode automatically.
DATABASE_URL=postgres://pf:changeme@postgres:5432/pf

# PostgreSQL service credentials (used by postgres service in docker-compose)
POSTGRES_DB=pf
POSTGRES_USER=pf
POSTGRES_PASSWORD=changeme

# ─── Authentication ───────────────────────────────────────────────────────────
# Secret for signing JWT session tokens.
# Generate with: openssl rand -hex 32
PF_JWT_SECRET=change-this-to-a-random-64-char-hex-string

# ─── SMTP (password reset emails) ────────────────────────────────────────────
# Leave blank to disable email-based password reset.
PF_SMTP_HOST=smtp.example.com
PF_SMTP_PORT=587
PF_SMTP_USER=user@example.com
PF_SMTP_PASS=your-smtp-password
PF_SMTP_FROM=noreply@your-domain.com

# ─── Redis ────────────────────────────────────────────────────────────────────
# Password for the Redis service (leave blank to disable auth in dev)
REDIS_PASSWORD=changeme

# ─── Backups ──────────────────────────────────────────────────────────────────
# How many days to retain local backup files (default: 7)
BACKUP_RETENTION_DAYS=7

# Optional: upload backups to S3-compatible storage
S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
# Override endpoint for non-AWS S3-compatible storage (e.g. Cloudflare R2, MinIO)
AWS_ENDPOINT_URL=
